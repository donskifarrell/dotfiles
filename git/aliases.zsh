#!/bin/sh

alias gl="git log --graph --decorate --oneline --abbrev-commit"
alias glga="gl --all"
alias gp='git push'
# alias gd='git diff' # replaced by forgit
alias gc='git commit'
alias gco='git checkout'
alias gb='git branch -v'
# alias ga='git add' # replaced by forgit
alias gs='git status -b'

# See forgit - https://github.com/wfxr/forgit
# ga - git add
# glo - git log
# gi - git ignore
# gd - git diff
# grh - git reset head
# gcf - git checkout 
# gss - git stash 
# gclean - git clean