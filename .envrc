# shellcheck shell=bash
# nix-direnv only watches flake.nix/flake.lock/.envrc by default, but this
# flake is dendritic: the devshell (and everything else) is assembled from
# modules/** and pkgs/**. Watch those too so edits re-trigger evaluation
# instead of serving a stale cached shell.
while IFS= read -r f; do
  watch_file "$f"
done < <(find modules pkgs -name '*.nix' 2>/dev/null)

use flake
